// firestore.rules
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection: only the authenticated user can read/write their own doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Progress subcollection
    match /users/{userId}/progress/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Flashcards subcollection (spaced repetition)
    match /users/{userId}/flashcards/{cardId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public content (lessons, kanji data) – read for all authenticated users
    match /content/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only via Firebase Console
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
